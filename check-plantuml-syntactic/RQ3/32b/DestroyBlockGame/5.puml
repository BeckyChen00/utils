
@startuml
' Set skinparam for better readability
skinparam class {
    BackgroundColor<<interface>> LightBlue
    ArrowColor Black
}

' Define classes

class User {
    - username: String (unique)
    - password: String
    + login(): void
    + logout(): void
}

class Player {
    - lives: int
    - currentGame: Game
    - score: int
    + playGame(game: Game): void
    + pauseGame(): void
    + resumeGame(): void
    + addScore(points: int): void
}

class Admin {
    + createGame(): Game
    + publishGame(game: Game): void
    + designGameBlocks(blocks: List<Block>): void
    + configureLevelSettings(levels: List<Level>): void
}

class Game {
    - name: String (unique)
    - admin: Admin
    - hallOfFame: HallOfFame
    - blocks: List<Block>
    - levels: List<Level>
    - minSpeed: float
    - speedIncreaseFactor: float
    - maxPaddleLength: int
    - minPaddleLength: int
    + isPublished: boolean
}

class Block {
    - color: Color
    - points: int (1-1000)
}

class Level {
    - levelNumber: int (1-99)
    - gridLayout: GridLayout
    - isRandom: boolean
    - initialBlocksCount: int
}

class GridLayout {
    - cells: Map<String, Block>  // e.g., "1/1", "2/3"
}

class HallOfFame {
    - highScores: List<HighScoreEntry>
    + addEntry(entry: HighScoreEntry): void
}

class HighScoreEntry {
    - player: Player
    - score: int
    - date: Date
}

class Ball {
    - position: Point
    - direction: Direction
    - speed: float
    + move(): void
    + bounce(): void
}

class Paddle {
    - position: Point
    - length: int
    + moveLeft(): void
    + moveRight(): void
}

class PlayArea {
    - ball: Ball
    - paddle: Paddle
    - blocks: List<Block>
    + updateGameState(): void
}

' Relationships

User <|-- Player
User <|-- Admin
Admin --> "1" Game : creates
Player --> "0..*" Game : plays
Game --> "1" HallOfFame
Game --> "1..*" Block : defines
Game --> "1..*" Level : has
Level --> "1" GridLayout : layout
Level --> "1..*" Block : contains (if not random)
HallOfFame --> "1..*" HighScoreEntry
HighScoreEntry --> "1" Player
PlayArea --> "1" Ball
PlayArea --> "1" Paddle
PlayArea --> "1..*" Block : active during game

' Interface-like marker for shared login functionality
[Login Interface] as Login
User ..|> Login

@enduml

---

### ✅ Notes:

- **Inheritance**: `Player` and `Admin` inherit from `User`, since every user is always a player and optionally an admin.
- **Composition/Aggregation**: 
  - A `Game` has one `Admin` and many `Levels` and `Blocks`.
  - Each `Level` may have its own `GridLayout`.
  - The `PlayArea` is part of a running session and contains the `Ball`, `Paddle`, and active `Blocks`.
- **Constraints**:
  - Only one admin per game.
  - Users cannot be both admin and player for the same game.
  - One game at a time can be played by a user.

