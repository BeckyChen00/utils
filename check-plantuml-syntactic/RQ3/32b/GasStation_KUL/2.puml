
---


@startuml

' Define classes and associations based on the requirements

class Customer {
    - id: String
    - name: String
    - status: Status (e.g., Active, Suspended)
    + hasFuelCard(): boolean
    + getUnpaidInvoices(): List<Invoice>
}

class FuelCard {
    - number: String
    - customer: Customer
    - active: boolean
    + addRefuelTurn(refuelTurn: RefuelTurn): void
}

class RefuelTurn {
    - id: String
    - fuelType: String
    - quantity: double
    - pricePerUnit: double
    - date: Date
    - paymentMethod: PaymentMethod
    - fuelCard: FuelCard (optional)
    - pump: Pump
    - station: GasStation
    + calculateTotalPrice(): double
}

enum PaymentMethod {
    Cash
    CreditCard
    FuelCard
}

class Invoice {
    - id: String
    - month: Date
    - totalAmount: double
    - discountsApplied: double
    - customer: Customer
    - refuelTurns: List<RefuelTurn>
    - sentDate: Date
    - paidDate: Date (optional)
    + applyDiscounts(): void
    + isPaid(): boolean
}

class Payment {
    - id: String
    - amount: double
    - date: Date
    - invoice: Invoice
}

class GasStation {
    - id: String
    - name: String
    - location: String
    - pumps: List<Pump>
    + generateDailyReport(): DailyReport
}

class Pump {
    - id: String
    - fuelType: String
    - reservoirCapacity: double
    - currentLevel: double
    - reorderLevel: double
    - criticalLevel: double
    - gasStation: GasStation
    - refuelTurns: List<RefuelTurn>
    - isBlocked: boolean
    + startRefueling(customer: Customer): void
    + stopRefueling(): void
    + needsRefill(): boolean
    + blockPump(duration: int): void
}

class DailyReport {
    - date: Date
    - pumpsToRefill: List<Pump>
    - quantitiesToOrder: Map<Pump, Double>
    + generate(): String
}

class DiscountPolicy {
    - customerType: CustomerType
    - discountRate: double
}

enum CustomerType {
    New
    Regular
    VeryGood
}

' Associations
Customer "1" -- "0..*" FuelCard : owns
Customer "1" -- "0..*" Invoice : receives
Customer "1" -- "0..*" RefuelTurn : participates in
FuelCard "1" -- "0..*" RefuelTurn : used for
FuelCard "1" -- "0..*" Invoice : appears in
GasStation "1" -- "0..*" Pump : contains
Pump "1" -- "0..*" RefuelTurn : assigned to
Pump "1" -- "0..*" DailyReport : reported in
Invoice "1" -- "1" Payment : paid by (optional)
Invoice "1" -- "0..*" RefuelTurn : includes
Customer "1" -- "1" DiscountPolicy : has

@enduml

---

### 🔍 Notes:

- **`Customer`** can have multiple `RefuelTurns`, and optionally a `FuelCard`.
- **`FuelCard`** tracks all refuels made with it.
- **`RefuelTurn`** is associated with a `Pump`, a `GasStation`, and a `PaymentMethod`.
- **`Invoice`** is generated monthly per customer and includes all unpaid `RefuelTurns` from that month.
- **`Pump`** has its own state (blocked/unavailable) due to maintenance or low fuel level.
- **`DailyReport`** is generated by each `GasStation` to track fuel levels and needed refills.
- **`DiscountPolicy`** varies depending on customer type (New/Regular/VeryGood).

