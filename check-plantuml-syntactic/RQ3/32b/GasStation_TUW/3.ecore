    <eStructuralFeatures xsi:type="ecore:EReference" name="String" eType="#//getFuels"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="octaneRating">
    <eStructuralFeatures xsi:type="ecore:EReference" name="Double" eType="#//pricePerLiter" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="pricePerLiter"/>
  <eClassifiers xsi:type="ecore:EClass" name="getFuel"/>
  <eClassifiers xsi:type="ecore:EClass" name="litersDispensed">
