@startuml

' Define Classes
class WebPortal {
  +String versionNumber
  +URL url
}

class Building {
  +String id
  +String name
  +EnergyClass energyClass
  +String address
  +int yearOfConstruction
  +User owner
  +List<Image> images
  +Image profilePhoto
}

class User {
  +String username
  +String email
  +String password
  +boolean isActive
  +WebPortal webPortal
}

class Administrator << stereotype "Administrator" >> extends User {
  +String idCardNumber
}

class Entry {
  +String name
  +User owner
  +Building building
  +boolean isPublic
}

class TextualEntry extends Entry {
  +String content
}

class NumericEntry extends Entry {
  +float value
  +String unit
}

class Image {
  +String fileName
  +Building building
}

class Comment {
  +String content
  +User author
  +Building building
  +Date timestamp
}

class EnergyClass {
  +String level (A, B, C, D)
}

' Relationships
User "1" -- "0..*" Building : owns
User "1" -- "0..*" Entry : creates
Building "1" -- "0..*" Entry : has
Building "1" -- "0..*" Comment : has
User "1" -- "0..*" Comment : posts
WebPortal "1" -- "0..*" Building : provides catalog of
WebPortal "1" -- "0..*" User : has registered users
Administrator "1" -- "1" WebPortal : administers
Building "1" -- "0..*" Image : contains
Building "1" -- "1" Image : has profile photo
Entry "1" -- "1" TextualEntry | NumericEntry : is either
User "1" -- "0..*" Administrator : may be an administrator

' Generalization
User <|-- Administrator
Entry <|-- TextualEntry
Entry <|-- NumericEntry

@enduml

