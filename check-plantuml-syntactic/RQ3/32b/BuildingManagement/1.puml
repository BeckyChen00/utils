@startuml

' Define classes and their attributes

class WebPortal {
    - version: String
    - url: String
}

class Building {
    - id: String
    - name: String
    - energyClass: String (A/B/C/D)
    - address: String
    - yearOfConstruction: int
    - profilePhoto: Image
    + addEntry(entry: Entry): void
    + addImage(image: Image): void
}

class User {
    - username: String
    - email: String
    - password: String
    - activated: boolean
    + createBuilding(): Building
    + manageEntries(building: Building): void
    + commentOnBuilding(building: Building): Comment
}

class Administrator {
    - idCardNumber: String
}

Administrator "1" --|> "1" User

class Entry {
    - name: String
    - releasedPublicly: boolean
}

class TextualEntry {
    - content: String
}

TextualEntry "1" --|> "1" Entry

class NumericEntry {
    - value: float
    - unit: String
}

NumericEntry "1" --|> "1" Entry

class Image {
    - fileName: String
}

class Comment {
    - text: String
    - author: User
    - building: Building
}

class RegistrationSystem {
    + registerUser(user: User): boolean
    + sendEmailVerification(user: User): void
}

' Relationships between classes

WebPortal "1" --> "many" Building : contains
Building "1" --> "many" Entry : has
Building "1" --> "many" Image : has
User "1" --> "many" Building : owns
User "1" --> "many" Comment : authored
Comment "1" --> "1" Building : comments on
Comment "1" --> "1" User : author
Administrator "1" --> "many" User : manages
Administrator "1" --> "many" Comment : deletes

@enduml

