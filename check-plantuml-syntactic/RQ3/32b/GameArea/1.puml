@startuml

' Game Area has a name and contains game elements and game pieces
class GameArea {
    name: String
}

' A GameElement has x and y coordinates
class GameElement {
    x: long
    y: long
}

' Shape is a type of GameElement
class Shape {
}

' Object is a type of GameElement
class Object {
}

' Opponent is a type of GameElement
class Opponent {
    lives: int
    kill()
}

' Boss is a specific type of Opponent
class Boss {
}

' Relationship between GameArea and GameElement (composition)
GameArea "1" -- "1..*" GameElement : contains

' GameArea has 1..2 GamePieces (not explicitly modeled here, but can be added if needed)

' GameElement inheritance
GameElement <|-- Shape
GameElement <|-- Object
GameElement <|-- Opponent

' Shape to Shape connection
Shape "0..*" -- "0..*" Shape : connectsTo

' GameArea knows one Boss
GameArea "1" -- "1" Boss : hasBoss

