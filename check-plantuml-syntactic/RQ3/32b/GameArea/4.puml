@startuml

' GameArea has a name
class GameArea {
    name : String
}

' GameElement has x and y values
class GameElement {
    x : long
    y : long
}

' Shape can connect to other Shapes
class Shape {
}

' Object (note: renamed from 'object' to avoid keyword)
class GameObject {
}

' Opponent has lives and can be killed
class Opponent {
    lives : int
    +kill()
}

' Boss is a special Opponent known by GameArea
class Boss {
}

' Relationships

GameArea "1" -- "1..*" GameElement : contains
GameArea "1" -- "1" Boss : knows #boss
GameElement <|-- Shape
GameElement <|-- GameObject
GameElement <|-- Opponent
Shape "0..*" -- "0..*" Shape : connectsTo #connection
Opponent <|-- Boss

@enduml

