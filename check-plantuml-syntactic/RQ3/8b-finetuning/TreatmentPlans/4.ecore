    <eStructuralFeatures xsi:type="ecore:EReference" name="outcomeDiagnosis" eType="#//Diagnosis" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Patient"/>
  <eClassifiers xsi:type="ecore:EClass" name="Doctor">
    <eStructuralFeatures xsi:type="ecore:EReference" name="issuedDiagnoses" eType="#//Diagnosis" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="authoredPlans" eType="#//TreatmentPlan" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="performedTreatments" eType="#//ActualTreatment" upperBound="-1"/>
  </eClassifiers>
