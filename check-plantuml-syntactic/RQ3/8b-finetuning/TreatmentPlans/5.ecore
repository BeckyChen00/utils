    <eStructuralFeatures xsi:type="ecore:EReference" name="grantedPermissions" eType="#//ExaminationPermission" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Doctor"/>
  <eClassifiers xsi:type="ecore:EClass" name="DiagnosisReport">
    <eStructuralFeatures xsi:type="ecore:EReference" name="supportingEvidence" eType="#//ExaminationRecord" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="diagnosedPatient" eType="#//Patient" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Treatment">
    <eStructuralFeatures xsi:type="ecore:EReference" name="includedExaminations" eType="#//ExaminationRecord" upperBound="-1" containment="true"/>
