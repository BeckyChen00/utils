    <eStructuralFeatures xsi:type="ecore:EReference" name="sessionAlerts" eType="#//Notification" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Notification"/>
  <eClassifiers xsi:type="ecore:EClass" name="MonthlyAward">
