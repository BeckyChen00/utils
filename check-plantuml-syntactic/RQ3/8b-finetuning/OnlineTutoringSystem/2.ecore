    <eStructuralFeatures xsi:type="ecore:EReference" name="conductedSessions" eType="#//TutoringSession" upperBound="-1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="PaymentTransaction"/>
