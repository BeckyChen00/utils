@startuml
enum ExhibitionStatus {
  Proposed
  Approved
  InProduction
  OnDisplay
  Closed
  Archived
}
class MuseumLocation {
  name: String
  capacity: int
}
class ExhibitionPlan {
  title: String
  status: ExhibitionStatus
  targetEndDate: Date
  +updateStatus(newStatus: ExhibitionStatus): void
  +getExhibitedItems(): List<ExhibitedItem>
}
class ExhibitionItem {
  name: String
  description: String
  requiredStatus: ExhibitionStatus
  currentStatus: ExhibitionStatus
  +addPiece(piece: MuseumPiece): void
  +removePiece(piece: MuseumPiece): void
  +selectPiece(candidate: MuseumPiece): boolean
}
class MuseumPiece {
  title: String
  artistName: String
  medium: String
  acquisitionYear: int
  condition: String
  +getArtist(): String
  +isAvailable(): boolean
}
class Collector {
  name: String
  contactInfo: String
  portfolioSize: int
  +creditsTotal: int
}
class Department {
  name: String
  budgetCode: String
  +getStaffMembers(): List<Employee>
}
class Employee {
  fullName: String
  employeeId: String
  role: String
  +assignCoach(coach: Employee): void
  +getTeamMembers(): List<Employee>
}
ExhibitionPlan "1" --> "1" MuseumLocation : location
ExhibitionPlan "1" *-- "*" ExhibitionItem : items
ExhibitionItem "1" --> "0..*" MuseumPiece : pieces
MuseumPiece "0..*" --> "1" Collector : owner
Department "1" --> "*" Employee : staffMembers 'opposite: affiliatedDepartment
Employee "1" --> "*" Employee : subordinates
Employee "1" --> "0..1" Employee : coach
@enduml