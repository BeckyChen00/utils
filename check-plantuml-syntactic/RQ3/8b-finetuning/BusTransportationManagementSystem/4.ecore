<?xml version='1.0' encoding='UTF-8'?>
<ecore:EPackage xmlns:xmi="http://www.omg.org/XMI" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="generated" nsURI="http://www.example.org/generated" nsPrefix="generated" xmi:version="2.0">
  <eClassifiers xsi:type="ecore:EClass" name="plantuml">
    <eStructuralFeatures xsi:type="ecore:EReference" name="managedRoutes" eType="#//BusRoute" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="BusRoute">
    <eStructuralFeatures xsi:type="ecore:EReference" name="defaultShiftTime" eType="#//ShiftTimeSlot" lowerBound="1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="assignedBuses" eType="#//Bus" upperBound="-1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="CityBusSystem">
    <eStructuralFeatures xsi:type="ecore:EReference" name="registeredDrivers" eType="#//Driver" upperBound="-1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="registeredBuses" eType="#//Bus" upperBound="-1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="generatedSchedules" eType="#//DailySchedule" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Driver">
    <eStructuralFeatures xsi:type="ecore:EReference" name="scheduledShifts" eType="#//DailySchedule" upperBound="-1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Bus">
    <eStructuralFeatures xsi:type="ecore:EReference" name="scheduledRides" eType="#//DailySchedule" upperBound="-1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="DailySchedule"/>
  <eClassifiers xsi:type="ecore:EClass" name="ShiftTimeSlot"/>
</ecore:EPackage>
