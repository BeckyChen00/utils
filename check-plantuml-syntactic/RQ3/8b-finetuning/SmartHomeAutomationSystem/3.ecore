<?xml version='1.0' encoding='UTF-8'?>
<ecore:EPackage xmlns:xmi="http://www.omg.org/XMI" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="generated" nsURI="http://www.example.org/generated" nsPrefix="generated" xmi:version="2.0">
  <eClassifiers xsi:type="ecore:EClass" name="plantuml">
    <eStructuralFeatures xsi:type="ecore:EReference" name="containedRooms" eType="#//Room" lowerBound="1" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Room">
    <eStructuralFeatures xsi:type="ecore:EReference" name="installedDevices" eType="#//Device" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Device">
    <eStructuralFeatures xsi:type="ecore:EReference" name="latestReading" eType="#//SensorReading"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="currentCommand" eType="#//ControlCommand"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="SensorReading"/>
  <eClassifiers xsi:type="ecore:EClass" name="ControlCommand"/>
  <eClassifiers xsi:type="ecore:EClass" name="SmartHome">
    <eStructuralFeatures xsi:type="ecore:EReference" name="activityHistory" eType="#//ActivityLog" lowerBound="1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="definedRules" eType="#//AutomationRule" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ActivityLog"/>
  <eClassifiers xsi:type="ecore:EClass" name="AutomationRule">
    <eStructuralFeatures xsi:type="ecore:EReference" name="executionPlan" eType="#//CommandSequence" lowerBound="1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="triggerCondition" eType="#//RuleCondition" lowerBound="1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="CommandSequence"/>
  <eClassifiers xsi:type="ecore:EClass" name="RuleCondition">
    <eStructuralFeatures xsi:type="ecore:EReference" name="monitoredDevices" eType="#//Device" upperBound="-1"/>
  </eClassifiers>
</ecore:EPackage>
