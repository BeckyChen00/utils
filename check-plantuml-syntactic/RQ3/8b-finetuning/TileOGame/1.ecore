<?xml version='1.0' encoding='UTF-8'?>
<ecore:EPackage xmlns:xmi="http://www.omg.org/XMI" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="generated" nsURI="http://www.example.org/generated" nsPrefix="generated" xmi:version="2.0">
  <eClassifiers xsi:type="ecore:EClass" name="plantuml">
    <eStructuralFeatures xsi:type="ecore:EReference" name="tiles" eType="#//Tile" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Tile">
    <eStructuralFeatures xsi:type="ecore:EReference" name="adjacents" eType="#//ConnectionPiece" upperBound="4" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="GameBoard">
    <eStructuralFeatures xsi:type="ecore:EReference" name="gameDeck" eType="#//ActionDeck" lowerBound="1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="gameDice" eType="#//Dice" lowerBound="1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="players" eType="#//Player" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="hiddenTile" eType="#//Tile" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ActionDeck"/>
  <eClassifiers xsi:type="ecore:EClass" name="Dice"/>
  <eClassifiers xsi:type="ecore:EClass" name="Player">
    <eStructuralFeatures xsi:type="ecore:EReference" name="pieces" eType="#//PlayingPiece" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="visitedTiles" eType="#//Tile" upperBound="-1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="PlayingPiece"/>
  <eClassifiers xsi:type="ecore:EClass" name="ConnectionPiece"/>
</ecore:EPackage>
