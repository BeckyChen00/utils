    <eStructuralFeatures xsi:type="ecore:EReference" name="gameDie" eType="#//Dice" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="GameDesigner">
    <eStructuralFeatures xsi:type="ecore:EReference" name="configuredSettings" eType="#//GameParameters" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="GameParameters"/>
  <eClassifiers xsi:type="ecore:EClass" name="Tile"/>
  <eClassifiers xsi:type="ecore:EClass" name="TileLayout">
    <eStructuralFeatures xsi:type="ecore:EReference" name="definedConnections" eType="#//ConnectionDefinition" upperBound="-1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="appliedLayout" eType="#//GameBoard" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ConnectionDefinition"/>
