    <eStructuralFeatures xsi:type="ecore:EReference" name="purchasedFuel" eType="#//Fuel" lowerBound="1"/>
    <eOperations xsi:type="ecore:EOperation" name="getFuelType" eType="#//Fuel"/>
  </eClassifiers>
