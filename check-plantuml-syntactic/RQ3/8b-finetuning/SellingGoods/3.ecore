    <eStructuralFeatures xsi:type="ecore:EReference" name="receivedInvoices" eType="#//Invoice" upperBound="-1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Order">
    <eStructuralFeatures xsi:type="ecore:EReference" name="orderLines" eType="#//OrderItem" lowerBound="1" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="OrderItem">
    <eStructuralFeatures xsi:type="ecore:EReference" name="orderedProduct" eType="#//Product" lowerBound="1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="deliveredIn" eType="#//Delivery"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Product"/>
