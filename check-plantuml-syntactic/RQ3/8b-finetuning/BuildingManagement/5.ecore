<?xml version='1.0' encoding='UTF-8'?>
<ecore:EPackage xmlns:xmi="http://www.omg.org/XMI" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="generated" nsURI="http://www.example.org/generated" nsPrefix="generated" xmi:version="2.0">
  <eClassifiers xsi:type="ecore:EClass" name="plantuml" eSuperTypes="#//Administrator"/>
  <eClassifiers xsi:type="ecore:EClass" name="Administrator">
    <eStructuralFeatures xsi:type="ecore:EReference" name="managedUsers" eType="#//User" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="deletedEntries" eType="#//AdditionalEntry" upperBound="-1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="WebPortal">
    <eStructuralFeatures xsi:type="ecore:EReference" name="managedBuildings" eType="#//Building" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Building">
    <eStructuralFeatures xsi:type="ecore:EReference" name="entries" eType="#//AdditionalEntry" upperBound="-1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="images" eType="#//Image" lowerBound="1" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="AdditionalEntry"/>
  <eClassifiers xsi:type="ecore:EClass" name="Image"/>
  <eClassifiers xsi:type="ecore:EClass" name="User">
    <eStructuralFeatures xsi:type="ecore:EReference" name="ownedBuildings" eType="#//Building" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="managedEntries" eType="#//AdditionalEntry" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="uploadedImages" eType="#//Image" upperBound="-1"/>
  </eClassifiers>
</ecore:EPackage>
