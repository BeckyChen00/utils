<?xml version='1.0' encoding='UTF-8'?>
<ecore:EPackage xmlns:xmi="http://www.omg.org/XMI" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="generated" nsURI="http://www.example.org/generated" nsPrefix="generated" xmi:version="2.0">
  <eClassifiers xsi:type="ecore:EClass" name="plantuml">
    <eStructuralFeatures xsi:type="ecore:EReference" name="maintenanceTag" eType="#//RecyclingTag" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="RecyclingTag"/>
  <eClassifiers xsi:type="ecore:EClass" name="collateralAsset">
    <eStructuralFeatures xsi:type="ecore:EReference" name="disposalHistory" eType="#//DisposalRecord" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="DisposalRecord">
    <eStructuralFeatures xsi:type="ecore:EReference" name="generatedBatch" eType="#//DisposalBatch" lowerBound="1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="disposalOwner" eType="#//User" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="DisposalBatch"/>
  <eClassifiers xsi:type="ecore:EClass" name="User"/>
</ecore:EPackage>
