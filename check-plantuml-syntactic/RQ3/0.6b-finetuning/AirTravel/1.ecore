    <eStructuralFeatures xsi:type="ecore:EReference" name="targetLocation" eType="#//CustomerAddress" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="CustomerAddress"/>
  <eClassifiers xsi:type="ecore:EClass" name="Shipment"/>
</ecore:EPackage>
