@startuml
enum ProductType {
  Wine
  Tea
  Coffee
  SoftDrink
  Tea
  Flower
  Music
}
enum StorageCondition {
  LowTemperature
  ModerateTemperature
  HighTemperature
  Sterile
}
class Product {
  productName: String
  productType: ProductType
  basePrice: double
  currentCondition: StorageCondition
  +validateInventory(): boolean
  +getUnitPrice(): double
  +requestRestock(): void
}
class Category {
  categoryName: String
  isVirtuallyReal: boolean
  +getSubCategory(): Category
}
class StoreManager {
  managerName: String
  +assignStore(store: Store): void
  +updateInventory(): void
}
class Viewport {
  viewportName: String
  isInteractive: boolean
  selectedQuery: String
  +toggleViewMode(): void
  +generateShareableCode(): String
}
class ProductCatalog {
  catalogName: String
  +findProduct(name: String): Product
  +getAllProducts(): List<Product>
}
class InventorySystem {
  systemLevel: int
  +updateStock(product: Product, quantity: int): void
  +verifyStock(product: Product, unit: QuantityUnit): boolean
  +calculateDiscountedPrice(product: Product): double
}
class QuantityUnit {
  quantity: int
  +convertToStock(): void
}
class Tag {
  tagName: String
  category: Category
  +getDescription(): String
}
class Tagset {
  tagNames: List<String>
  +addTag(tag: Tag): void
  +removeTag(tag: Tag): void
}
class DisplaySettings {
  screenWidth: int
  screenHeight: int
  backgroundColor: String
  +configureViewport(viewport: Viewport): void
}
class CartItem {
  quantity: int
  unit: QuantityUnit
  +checkout(): void
  +updateQuantity(n: int): void
}
class Basket {
  basketName: String
  +addItem(item: CartItem): void
  +removeItem(item: CartItem): void
  +getTotalAmount(): double
}
class CustomerProfile {
  contactEmail: String
  +addOrder(order: Order): void
}
class Order {
  orderDate: Date
  status: String
  +placeOrder(items: List<CartItem>): void
  +cancelOrder(reason: String): void
}
class OrderEntry {
  entryDate: Date
  isExpress: boolean
  +calculateTotal(): double
}
class OrderInvoice {
  invoiceNumber: String
  currency: String
  issueDate: Date
  +generateInvoice(): void
  +processPayment(amount: double): boolean
}
class PaymentTransaction {
  amount: double
  paymentMethod: String
  +validate(): boolean
  +processPayment(): boolean
}
class AuditLog {
  timestamp: Date
  actionDescription: String
  performer: String
  +recordAction(action: String, user: String): void
}
class SecurityCertificate {
  expiresAt: Date
  +issue(): void
  +validate(): boolean
}
class LicensePlate {
  licenseNumber: String
  +getLicenseName(): String
}
class LicenseReview {
  reviewDate: Date
  +calculateCost(completed: boolean): double
  +checkProgress(reviewer: String): boolean
}
class ShippingAddress {
  cityName: String
  postalCode: String
  country: String
  +formatAddress(): String
}
class ShippingAddress {
  countryCode: String
  city: String
  postalCode: String
}
class Quote {
  quoteNumber: String
  issueDate: Date
  totalAmount: double
  +calculatePrice(): double
  +isValid(): boolean
}
class OrderLine {
  productCount: int
  quantity: int
  basePrice: double
  +getSubtotal(): double
}
class ProductPrice {
  applicableCondition: StorageCondition
  regularPrice: double
  +applyDiscount(condition: StorageCondition): double
}
class NotificationService {
  emailEnabled: boolean
  +sendAlert(message: String, isRead: boolean): void
  +sendOrderStatus(order: Order): void
}
class SalesRecord {
  saleDate: Date
  transactionAmount: double
  +generateReceipt(): String
}
class ComplaintReport {
  issueDescription: String
  reportedBy: String
  responseDate: Date
  +submit(): void
}
class SalesDataAggregator {
  +aggregateSales(provenance: String, period: DateRange): Map<Store, Map<StorageCondition, double>>
}
class CatalogProcessor {
  parserFormat: String
  +processContent(text: String): List<Product>
  +applyFilters(caseSensitive: boolean, threshold: int): List<Product>
}
class LanguageProvider {
  languageCode: String
  +translateText(text: String, targetLanguage: String): String
  +translateDescription(product: Product): String
}
class PriceCalculator {
  calculationAlgorithm: String
  +computeDiscounted(price: double, discount: double): double
  +computeFinalPrice(saleDate: Date, isExempt: boolean): double
}
