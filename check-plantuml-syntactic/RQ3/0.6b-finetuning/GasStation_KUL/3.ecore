<?xml version='1.0' encoding='UTF-8'?>
<ecore:EPackage xmlns:xmi="http://www.omg.org/XMI" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="generated" nsURI="http://www.example.org/generated" nsPrefix="generated" xmi:version="2.0">
  <eClassifiers xsi:type="ecore:EClass" name="plantuml">
    <eStructuralFeatures xsi:type="ecore:EReference" name="managedTargets" eType="#//AlertTarget" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="AlertTarget"/>
  <eClassifiers xsi:type="ecore:EClass" name="AlertEngine">
    <eStructuralFeatures xsi:type="ecore:EReference" name="activeRules" eType="#//AlertRule" upperBound="-1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="sourceReadings" eType="#//SensorReading" upperBound="-1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="targetedChannels" eType="#//NotificationChannel" upperBound="-1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="generatedAlerts" eType="#//AlertMessage" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="recordedLogs" eType="#//SystemLog" upperBound="-1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="AlertRule">
    <eStructuralFeatures xsi:type="ecore:EReference" name="actionTarget" eType="#//AlertTarget" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="SensorReading"/>
  <eClassifiers xsi:type="ecore:EClass" name="NotificationChannel"/>
  <eClassifiers xsi:type="ecore:EClass" name="AlertMessage">
    <eStructuralFeatures xsi:type="ecore:EReference" name="sourceReading" eType="#//SensorReading" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="SystemLog"/>
  <eClassifiers xsi:type="ecore:EClass" name="AlarmTrigger"/>
</ecore:EPackage>
