    <eStructuralFeatures xsi:type="ecore:EReference" name="sourceZone" eType="#//MonitoringZone" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="DataPacket"/>
  <eClassifiers xsi:type="ecore:EClass" name="TimeSeriesRecord"/>
</ecore:EPackage>
