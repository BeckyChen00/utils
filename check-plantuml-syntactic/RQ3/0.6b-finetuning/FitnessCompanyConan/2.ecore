    <eStructuralFeatures xsi:type="ecore:EReference" name="mappedSensors" eType="#//Sensor" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="MonitoringZone">
    <eStructuralFeatures xsi:type="ecore:EReference" name="containedSensors" eType="#//Sensor" upperBound="-1" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="sourceFeed" eType="#//TelemetryFeed" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Sensor"/>
