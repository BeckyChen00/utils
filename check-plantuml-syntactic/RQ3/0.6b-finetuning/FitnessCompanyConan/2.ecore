  <eClassifiers xsi:type="ecore:EClass" name="plantuml">
    <eStructuralFeatures xsi:type="ecore:EReference" name="coverageMap" eType="#//CoverageMap" lowerBound="1" containment="true"/>
  </eClassifiers>
