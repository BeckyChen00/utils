<?xml version='1.0' encoding='UTF-8'?>
<ecore:EPackage xmlns:xmi="http://www.omg.org/XMI" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="generated" nsURI="http://www.example.org/generated" nsPrefix="generated" xmi:version="2.0">
  <eClassifiers xsi:type="ecore:EClass" name="plantuml">
    <eStructuralFeatures xsi:type="ecore:EReference" name="ownedDatasets" eType="#//Dataset" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Dataset"/>
  <eClassifiers xsi:type="ecore:EClass" name="ResearchProject">
    <eStructuralFeatures xsi:type="ecore:EReference" name="primaryAnalysis" eType="#//DatasetAnalysis" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="DatasetAnalysis">
    <eStructuralFeatures xsi:type="ecore:EReference" name="generatedReports" eType="#//Report" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Report"/>
</ecore:EPackage>
