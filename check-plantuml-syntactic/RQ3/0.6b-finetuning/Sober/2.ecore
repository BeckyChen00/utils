<?xml version='1.0' encoding='UTF-8'?>
<ecore:EPackage xmlns:xmi="http://www.omg.org/XMI" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="generated" nsURI="http://www.example.org/generated" nsPrefix="generated" xmi:version="2.0">
  <eClassifiers xsi:type="ecore:EClass" name="plantuml">
    <eStructuralFeatures xsi:type="ecore:EReference" name="connectedSensors" eType="#//SensorNode" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="SensorNode"/>
  <eClassifiers xsi:type="ecore:EClass" name="Vehicle">
    <eStructuralFeatures xsi:type="ecore:EReference" name="assignedJobs" eType="#//MaintenanceJob" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="assignedTasks" eType="#//Task" upperBound="-1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="MaintenanceJob">
    <eStructuralFeatures xsi:type="ecore:EReference" name="targetVehicle" eType="#//Vehicle" lowerBound="1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="scheduledOn" eType="#//MaintenanceSchedule"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Task"/>
  <eClassifiers xsi:type="ecore:EClass" name="MaintenanceSchedule"/>
</ecore:EPackage>
