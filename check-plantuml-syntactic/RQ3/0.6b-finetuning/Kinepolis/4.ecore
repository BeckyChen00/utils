  <eClassifiers xsi:type="ecore:EClass" name="SystemMonitor">
    <eStructuralFeatures xsi:type="ecore:EReference" name="monitoredSteps" eType="#//SimulationStep" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="monitoredSessions" eType="#//ActivitySession" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="trackedMetrics" eType="#//PerformanceMetric" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="generatedLogs" eType="#//LogEvent" upperBound="-1"/>
