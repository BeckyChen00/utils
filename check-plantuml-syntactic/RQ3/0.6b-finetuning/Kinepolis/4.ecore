    <eStructuralFeatures xsi:type="ecore:EReference" name="allocatedResources" eType="#//ResourceAllocation" lowerBound="1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TimeWindow"/>
  <eClassifiers xsi:type="ecore:EClass" name="ResourceAllocation"/>
  <eClassifiers xsi:type="ecore:EClass" name="TaskScheduler">
    <eStructuralFeatures xsi:type="ecore:EReference" name="managedSession" eType="#//ActivitySession" lowerBound="1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="scheduledSteps" eType="#//SimulationStep" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="managedResources" eType="#//ResourceAllocation" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="managedTasks" eType="#//SimulationStep" upperBound="-1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="JobQueue"/>
