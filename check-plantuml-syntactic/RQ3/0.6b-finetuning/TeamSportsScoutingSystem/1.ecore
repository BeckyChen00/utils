    <eStructuralFeatures xsi:type="ecore:EReference" name="targetedTargets" eType="#//CrimeUtis" upperBound="-1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="responsibleEnterprise" eType="#//Enterprise" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="AlertNotification"/>
  <eClassifiers xsi:type="ecore:EClass" name="CrimeSuspect"/>
  <eClassifiers xsi:type="ecore:EClass" name="CrimeUtis"/>
