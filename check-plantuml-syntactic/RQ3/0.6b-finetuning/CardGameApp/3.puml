PrintJob --> "1" PrinterDevice : assignedPrinter
PrintJob --> "1" PrintTimer : usedTimer
WorkStation --> "0..*" ProductionSchedule : ownedSchedules
WorkStation --> "0..*" WorkOrder : processedWorkOrders
WorkStation --> "0..*" SafetyInspector : assignedInspectors
WorkOrder --> "0..*" SlipWarning : generatedSlips
