@startuml
enum MaterialType {
  Paper
  Cardboard
  Plastic
  Metal
  Glass
  Rubber
  Composite
  Synthetic
  Hazardous
}
enum OrthographicView {
  SideView
  FrontView
  TopView
}
class WarehouseItem {
  itemName: String
  materialType: MaterialType
  stockQuantity: int
  +getQuantity(): int
  +updateStock(amount: int): void
}
class DocumentDefinition {
  versionNumber: int
  documentType: String
  creationDate: Date
  +validate(): boolean
}
class PrintJob {
  printOrderNumber: String
  printDate: Date
  targetView: OrthographicView
  +estimateProcessingTime(): int
  +execute(): int
}
class ProductionSchedule {
  startDate: Date
  targetProductionVolume: int
  +getNextAvailableSlot(): Date
  +generateBatchCount(): int
}
class QualityInspection {
  inspectionDate: Date
  inspectorName: String
  isPassed: boolean
  notes: String
  +recordResult(isPassed: boolean, remarks: String): void
  +generateReport(): String
}
class MaterialSupplier {
  supplierName: String
  contactEmails: String
  +supplyMaterial(item: WarehouseItem, quantity: int): void
}
class WarehouseZone {
  zoneName: String
  totalCapacity: int
  +allocateSpace(quantity: int): boolean
}
class ProductionBatch {
  batchIdentifier: String
  creationDate: Date
  +calculateTotalDuration(): int
  +logInspection(inspection: QualityInspection): void
}
class PrintController {
  isOnline: boolean
  +configureCircuit(status: boolean): void
  +monitorPrintQueue(): void
  +generateJobReport(): String
}
class PrinterDevice {
  isOperational: boolean
  +startOperation(): void
  +stopOperation(): void
  +getRepairLog(): String
}
class InventoryManager {
  accuracyThreshold: int
  +countAlerts(): int
  +fetchAvailableStock(zone: WarehouseZone): int
  +notifySupplier(order: ProductionSchedule): void
}
class PrinterUnit {
  currentLoad: int
  +powerOn(): void
  +powerOff(): void
  +getPerformanceStatus(): String
}
class CalibrationService {
  +checkCalibration(device: PrinterDevice): boolean
  +resetDevice(): void
}
class ProductionShift {
  shiftDurationMinutes: int
  shiftStartDate: Date
  shiftEndDate: Date
  +assignBatch(batch: ProductionBatch): void
  +getCurrentJobCount(): int
}
class BatchInventory {
  batchCount: int
  +validateBatch(): boolean
}
class AlertNotification {
  notificationSeverity: int
  messageContent: String
  +sendNotification(recipientList: String[]): void
}
class WorkOrder {
  orderNumber: String
  description: String
  priority: int
  +updatePriority(newPriority: int): void
  +startProduction(): ProductionSchedule
}
class SafetyInspector {
  +verifyRoute(route: String): boolean
  +calculateRiskScore(route: String, duration: int): int
}
class ResourceAllocation {
  resourceType: String
  +allocateSlot(shift: ProductionShift, slot: int): void
  +allocateSpace(zone: WarehouseZone, quantity: int): boolean
}
class ProductionScheduleGenerator {
  +generateNextSchedule(): ProductionSchedule
  +scheduleBatch(batch: ProductionBatch): void
}
class JobScheduler {
  +triggerJob(job: PrintJob): void
  +scheduleBatch(batch: ProductionBatch): void
  +getActiveJobs(): List<PrintJob>
}
class MaterialProvider {
  +supplyMaterial(item: WarehouseItem, quantity: int): boolean
  +getSupplierList(): List<MaterialSupplier>
}
class DocumentMaker {
  printResolution: int
  +renderDocument(content: String, format: String): String
  +createView(documentDefinition: DocumentDefinition): OrthographicView
}
class MaintenanceLog {
  logDate: Date
  technicianName: String
  issueDescription: String
  resolutionSteps: String
  +archiveLog(): void
}
class SafetyRegulation {
  regulationCode: String
  description: String
  +checkCompliance(batch: ProductionBatch): boolean
}
class CostEstimator {
  unitPrice: double
  +getEstimatedCost(batch: ProductionBatch, material: WarehouseItem): double
  +calculateTotalBatchSize(): int
}
class Workstation {
  workstationName: String
  +startStation(batch: ProductionBatch): void
  +stopStation(): void
}
class PrintShop {
  shopName: String
  +getShopName(): String
  +getShopCapacity(): int
}
class PrinterFactory {
}
class PrintTimer {
  +startTimer(): void
  +stopTimer(): int
  +getCurrentTime(): Date
}
class SlipWarning {
  slipType: String
  severityLevel: int
  description: String
  +notifyDispatch(dispatcher: String): void
}
WorkOrder --> "1" ProductionSchedule : generatedSchedule
ProductionSchedule *-- "0..*" ProductionBatch : containedBatches
ProductionSchedule *-- "1" ProductionShift : assignedShift
ProductionSchedule --> "1" ResourceAllocation : resourceAllocation
ProductionSchedule --> "0..1" SafetyInspector : responsibleInspector
