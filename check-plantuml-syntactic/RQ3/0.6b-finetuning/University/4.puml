@startuml
class User {
  username: String
  +login(): boolean
  +logout(): void
}
class Room {
  roomName: String
  capacity: int
  isOccupied: boolean
  +checkAvailability(): boolean
}
class Player {
  nickname: String
  staminaLevel: int
  healthPoints: int
