<?xml version='1.0' encoding='UTF-8'?>
<ecore:EPackage xmlns:xmi="http://www.omg.org/XMI" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="generated" nsURI="http://www.example.org/generated" nsPrefix="generated" xmi:version="2.0">
  <eClassifiers xsi:type="ecore:EClass" name="plantuml">
    <eStructuralFeatures xsi:type="ecore:EReference" name="agents" eType="#//Agent" upperBound="-1" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Agent"/>
  <eClassifiers xsi:type="ecore:EClass" name="AgentSession">
    <eStructuralFeatures xsi:type="ecore:EReference" name="activeAgent" eType="#//Agent" lowerBound="1"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="factory" eType="#//AgentFactory" lowerBound="1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="AgentFactory">
    <eStructuralFeatures xsi:type="ecore:EReference" name="definedRules" eType="#//PolicyRule" upperBound="-1"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="PolicyRule"/>
</ecore:EPackage>
