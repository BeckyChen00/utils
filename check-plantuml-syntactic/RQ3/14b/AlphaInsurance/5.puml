
@startuml

' Define classes
class Customer {
  -id: int
  -name: String
  -contactInfo: String
  -broker: Broker
}

class Broker {
  -id: int
  -name: String
  -contactInfo: String
  -assignedCustomers: List<Customer>
}

class InsurancePolicy {
  -id: int
  -type: String
  -description: String
  -price: double
  -term: String
}

class Contract {
  -id: int
  -customer: Customer
  -policy: InsurancePolicy
  -broker: Broker
  -startDate: Date
  -endDate: Date
  -paymentFrequency: String
}

class Claim {
  -id: int
  -customer: Customer
  -contract: Contract
  -claimDate: Date
  -status: String
  -claimDetails: String
  -compensationAmount: double
  -estimatorsReports: List<EstimatorReport>
}

class EstimatorReport {
  -id: int
  -claim: Claim
  -estimator: Estimator
  -reportDate: Date
  -details: String
  -approved: boolean
}

class Estimator {
  -id: int
  -name: String
  -specialization: String
  -reports: List<EstimatorReport>
}

class Invoice {
  -id: int
  -contract: Contract
  -amount: double
  -dueDate: Date
  -paid: boolean
}

class CompensationDecision {
  -id: int
  -claim: Claim
  -eligibleCosts: double
  -decisionDate: Date
  -approvedBy: String
}

' Define relationships
Customer "1" -- "0..*" Broker : assigned to
Broker "1" -- "0..*" Customer : manages
Customer "1" -- "0..*" Contract : has
Broker "1" -- "0..*" Contract : handles
InsurancePolicy "1" -- "0..*" Contract : offered in
Contract "1" -- "1" Invoice : generates
Claim "1" -- "1" CompensationDecision : results in
Claim "1" -- "0..*" EstimatorReport : includes
EstimatorReport "1" -- "1" Estimator : produced by
Claim "1" -- "1" Contract : belongs to

@enduml

---

### 📌 Explanation of Key Classes:
- **Customer**: Represents an individual or entity that purchases insurance.
- **Broker**: Handles customer interactions, assigns contracts, and communicates with customers.
- **InsurancePolicy**: Defines different types of insurance products.
- **Contract**: The signed agreement between the customer and Alpha Insurance.
- **Claim**: A request from a customer for compensation due to an insured event.
- **EstimatorReport**: Report generated by estimators regarding a claim.
- **Estimator**: Experts who assess claims.
- **Invoice**: Billing document generated after contract signing.
- **CompensationDecision**: Final decision on which costs are covered by the insurance.

