@startuml

class diagram: System Requirements

class Diagram {
  class System Requirement {
    class Name: "System Requirement"
    class Description: "This is a system requirement for the application."
    class Required Components: [Component1, Component2]
    class Dependencies: [Dependency1, Dependency2]
  }

  class Component1 {
    class Name: "Component A"
    class Description: "A component that supports functionality."
  }

  class Component2 {
    class Name: "Component B"
    class Description: "Another component for the application."
  }

  class Dependency1 {
    class Name: "Dependency A"
    class Description: "A dependency required by Component A."
  }

  class Dependency2 {
    class Name: "Dependency B"
    class Description: "A dependency required by Component B."
  }

  # Relationships between components and dependencies
  node Relationship1 from Component1 to Dependency1
  node Relationship2 from Component2 to Dependency2

@enduml
