}

class Apartment {
    +address: String
    +rooms: List<Room>
    +inhabitants: List<Inhabitant>
    +login(username: String, password: String): Boolean
    +querySensorValues(Sensor sensor): List<Value>
    +setEmail(String email)
    +getSensor(String sensorId): Sensor
}

class Inhabitant {
    +username: String
    +password: String
    +isAdmin: Boolean
    +login(username: String, password: String): Boolean
    +configureSensor(Sensor sensor)
}

class EMonitor {
    +checkThresholds()
    +sendAlertMessage(String message, String email)
}

' Associations
Sensor --> Room
Sensor --> Value
