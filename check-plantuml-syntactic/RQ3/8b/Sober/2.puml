@startuml
skinparam classAttributeIconSize 0

class User {
    +String id
    +String name
    +String phone
    +String email
    +boolean isCarOwner
    +List<Car> ownedCars
    +List<Ride> rides
}

class Car {
    +String id
    +String licensePlate
    +String model
    +String color
    +String ownerID
    +boolean isSelfDriving
    +List<Ride> rides
    +List<Accident> accidents
}

class Ride {
    +String id
    +LocalDateTime startTime
    +LocalDateTime endTime
    +Location pickupLocation
    +Location dropoffLocation
